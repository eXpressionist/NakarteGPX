# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Cache Configuration
# File cache is the default and is stored indefinitely in ./cache or the Docker cache_data volume.
CACHE_TYPE=file
# CACHE_DIR=./cache
# CACHE_TTL=2592000
# CACHE_MAX_BYTES=1073741824

# Optional Redis Configuration
# Set CACHE_TYPE=redis and provide these values only if you run Redis separately.
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Logging Configuration
LOG_LEVEL=INFO

# Browser Configuration
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
# NAKARTE_APP_READY_TIMEOUT=8000
# DOWNLOAD_CONCURRENCY=1

# Security Limits
# RATE_LIMIT_REQUESTS=5
# RATE_LIMIT_WINDOW_SECONDS=60
# MAX_PENDING_DOWNLOADS=10
# MAX_GPX_FILES=20
# MAX_GPX_BYTES=20971520

# Admin Statistics
# Comma-separated Telegram user IDs allowed to use /stats.
# ADMIN_USER_IDS=123456789,987654321
# STATS_DB_PATH=./stats/bot_stats.sqlite3
# STATS_HASH_SALT=

# Application Configuration
APP_NAME=NakarteGPXBot
