# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Cache Configuration
# File cache is the default and is stored indefinitely in ./cache or the Docker cache_data volume.
CACHE_TYPE=file

# Optional Redis Configuration
# Set CACHE_TYPE=redis and provide these values only if you run Redis separately.
# CACHE_TTL=86400
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Logging Configuration
LOG_LEVEL=INFO

# Browser Configuration
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# Application Configuration
APP_NAME=NakarteGPXBot
